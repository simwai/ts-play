{
  "extends": "@sindresorhus/tsconfig",
  "compilerOptions": {
    "target": "es2023",
    "lib": ["ESNext", "WebWorker"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["**/*.ts"]
}
